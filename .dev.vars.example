# Local development config for wrangler pages dev. Copy to .dev.vars (gitignored).
ENVIRONMENT=dev
RP_ID=localhost
ORIGIN=http://localhost:5173
AUTH_SECRET=dev-only-secret-not-for-production
# Optional: set a Resend API key to actually e-mail sign-in codes in local dev.
# Leave unset to show codes only in the local UI.
# RESEND_API_KEY=re_...
