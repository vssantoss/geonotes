# Vite build-time config for the client bundle. Copy to .env (gitignored).
# These are baked into the built assets at `pnpm build`, so rebuild after changes.

# Public Cloudflare Turnstile sitekey for the sign-in flow. When set, the auth
# screen renders the Turnstile widget and sends its token with each code request;
# leave empty to disable the widget (must match the server: unset TURNSTILE_SECRET).
# The sitekey is public and the widget is domain-restricted, so it is safe to ship.
# VITE_TURNSTILE_SITEKEY=0x...
